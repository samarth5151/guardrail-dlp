{
  "manifest_version": 3,
  "name": "Barclays DLP Guardian",
  "version": "2.0.0",
  "description": "Enterprise DLP: Intercepts prompts to all major AI sites. Scans for credentials, PII, financial data, prompt injection and more before allowing submission.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "identity",
    "webRequest"
  ],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://claude.ai/*",
    "https://copilot.microsoft.com/*",
    "https://perplexity.ai/*",
    "https://grok.x.ai/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://dlp-api.internal.barclays.com/*",
    "http://localhost:8001/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*",
        "https://perplexity.ai/*",
        "https://grok.x.ai/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "storage": {
    "managed_schema": "managed_storage_schema.json"
  }
}
